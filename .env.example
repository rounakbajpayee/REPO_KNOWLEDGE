# Qdrant (Tailscale)
QDRANT_URL=http://<your-host>:6333

# Ollama (Tailscale)
OLLAMA_URL=http://<your-host>:11434

# Embedding model — must match exactly what `ollama list` shows
# nomic-embed-text      → EMBEDDING_DIM=768,  QDRANT_COLLECTION=code_chunks_nomic
# qwen3-embedding:4b    → EMBEDDING_DIM=2560, QDRANT_COLLECTION=code_chunks_qwen3
#
# NOTE: qwen3-embedding:4b outputs 2560-dim vectors despite the 4B name.
# If you recreate the collection manually, use 2560.
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIM=2560

# Qdrant collection name — include model slug to support benchmarking
QDRANT_COLLECTION=code_chunks_qwen3

# Ollama timeout in seconds — large models take 60-90s on first load
OLLAMA_TIMEOUT=120

# Root directory to scan for repositories
PROJECTS_ROOT=C:\\Users\\rouna\\seadrive\\rounak\\My Libraries\\Home\\Projects

# How many chunks to return per search
SEARCH_TOP_K=5

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
