# Qdrant (Tailscale)
QDRANT_URL=http://100.70.3.86:6333

# Ollama (Tailscale)
OLLAMA_URL=http://100.70.3.86:11434

# Embedding model — must match exactly what `ollama list` shows
# nomic-embed-text      → EMBEDDING_DIM=768,  QDRANT_COLLECTION=code_chunks_nomic
# qwen3-embedding:4b    → EMBEDDING_DIM=1024, QDRANT_COLLECTION=code_chunks_qwen3
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIM=1024

# Qdrant collection name — include model slug to support benchmarking
QDRANT_COLLECTION=code_chunks_qwen3

# Ollama timeout in seconds — large models take 60-90s on first load
OLLAMA_TIMEOUT=120

# Root directory to scan for repositories
PROJECTS_ROOT=/Users/rounak/Projects

# How many chunks to return per search
SEARCH_TOP_K=5
